{
  "name": "noticiencias-astro",
  "type": "module",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run publish:image-derivatives && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:audit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:content-quality": "node scripts/check-content-quality.js",
    "check:frontmatter-dates": "node scripts/check-frontmatter-dates.js",
    "check:hero-images": "node scripts/check-hero-images.js",
    "check:published-sidecars": "node scripts/check-published-sidecars.js",
    "sync:hero-placeholders": "node scripts/sync-hero-placeholders.js",
    "check:image-derivatives": "node scripts/check-image-derivatives.js",
    "check:r2-image-quota": "node scripts/r2-image-quota-guard.js",
    "publish:image-derivatives": "node scripts/publish-image-derivatives.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run check:frontmatter-dates && npm run check:hero-images && npm run check:published-sidecars && npm run check:image-derivatives && npm run check:content-quality && npm run format:check && eslint .",
    "lint-fix": "prettier --write . && eslint . --fix",
    "check:contract-sync": "node scripts/check-contract-sync.js ${BACKEND_SCHEMA_PATH:-../noticiencias_news_collector/news_collector/contracts/frontend_schema.py} src/content/config.ts",
    "check:tags": "node scripts/check-tags.js",
    "check:freeze": "node scripts/freeze-template.js",
    "test:dist": "node scripts/dist-sanity.js",
    "test:deploy": "node scripts/post-deploy-check.js",
    "validate:content": "npm run check:frontmatter-dates && npm run check:hero-images && npm run check:published-sidecars && npm run check:image-derivatives && npm run check:content-quality && npm run check:tags && astro sync && astro check && npm run check:freeze"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.1",
    "@astrojs/tailwind": "^6.0.2",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/playfair-display": "^5.2.8",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.26",
    "@tailwindcss/typography": "0.5.19",
    "astro": "^6.1.6",
    "astro-embed": "^0.12.0",
    "astro-icon": "^1.1.5",
    "autoprefixer": "10.4.23",
    "csv-parse": "^6.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "limax": "^4.2.2",
    "lodash.merge": "^4.6.2",
    "lunr": "^2.3.9",
    "postcss": "8.5.6",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "3.4.19",
    "unpic": "^4.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/lunr": "^2.3.7",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "4.0.18",
    "cheerio": "^1.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-security": "^3.0.1",
    "glob": "^13.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "lodash": "4.17.23",
    "yaml": ">=2.8.3"
  }
}
