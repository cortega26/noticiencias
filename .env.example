# Cloudflare R2 / CDN image delivery
# All variables below are OPTIONAL in local development.
# Without them, the site uses Astro's built-in image optimization from public/images/.

# Set to "r2" to enable CDN delivery; defaults to "local"
# IMAGE_DELIVERY_MODE=local

# Required only when IMAGE_DELIVERY_MODE=r2
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://cdn.example.com

# Strict derivative enforcement (set by CI automatically when R2 is configured)
# IMAGE_DERIVATIVES_REQUIRE_URL=0
# IMAGE_DERIVATIVES_STRICT=0

# ---------------------------------------------------------------------------
# Backend webhook (optional)
# URL del webhook del backend para recibir notificaciones de validación y deploy.
# Si no se configura, las notificaciones se omiten silenciosamente.
# BACKEND_WEBHOOK_URL=https://api.example.com/webhooks/noticiencias

# ---------------------------------------------------------------------------
# Cloudflare Worker (para despliegue del worker en workers/)
# Estos valores van como GitHub Secrets, NO en .env:
#   CLOUDFLARE_API_TOKEN     — API token con permisos Workers y R2
#   CLOUDFLARE_ACCOUNT_ID    — ID de la cuenta Cloudflare
#   BACKEND_WEBHOOK_URL      — URL del webhook del backend (opcional)

# ---------------------------------------------------------------------------
# Playwright E2E tests
# PLAYWRIGHT_BASE_URL        — URL base para tests (default: https://noticiencias.com)
#   Para tests locales: PLAYWRIGHT_BASE_URL=http://localhost:4321 npx playwright test
