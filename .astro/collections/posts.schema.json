{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5
    },
    "schema_version": {
      "default": 1,
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "excerpt": {
      "type": "string",
      "minLength": 10
    },
    "author": {
      "default": "Noticiencias",
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "categories": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "src": {
              "type": "string"
            },
            "width": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "height": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "alt": {
              "type": "string"
            }
          },
          "required": [
            "src",
            "width",
            "height"
          ]
        }
      ]
    },
    "image_alt": {
      "type": "string"
    },
    "permalink": {
      "type": "string"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "refinery_id": {
      "type": "string"
    },
    "headlines_variants": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string"
        },
        "benefit": {
          "type": "string"
        }
      }
    },
    "translation_method": {
      "type": "string"
    },
    "editorial_score": {
      "type": "number"
    },
    "review_status": {
      "type": "string"
    },
    "confidence": {
      "type": "string"
    },
    "investigation": {
      "default": false,
      "type": "boolean"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "fact_check": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "label",
          "status"
        ]
      }
    },
    "why_it_matters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "series": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": {
            "type": "string"
          },
          "date": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "excerpt",
    "date",
    "image"
  ]
}