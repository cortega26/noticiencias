---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/BaseLayout.astro';
import { cleanSlug } from '~/utils/permalinks';

const posts = await getCollection('posts');
const seriesSet = new Set<string>();
const seriesList: string[] = [];

posts.forEach((post) => {
  if (post.data.series && !seriesSet.has(post.data.series)) {
    seriesSet.add(post.data.series);
    seriesList.push(post.data.series);
  }
});

const metadata = {
  title: 'Series de Investigación | Noticiencias',
  description:
    'Cobertura a profundidad sobre los temas más complejos de la ciencia, la tecnología y el internet de interés público.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mb-8 border-b border-border-subtle pb-5">
      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-5xl">
        Series de investigación
      </h1>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-text-muted">
        Lecturas agrupadas para seguir una historia científica o tecnológica con más continuidad.
      </p>
    </header>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        seriesList.length === 0 ? (
          <p class="text-center text-gray-500 col-span-full">
            Próximamente: Nuevas series en desarrollo.
          </p>
        ) : (
          seriesList.map((series) => (
            <a
              href={`/series/${cleanSlug(series)}`}
              class="block border border-border-subtle p-5 hover:border-primary"
            >
              <h2 class="font-heading text-xl font-bold text-text-body">{series}</h2>
              <span class="mt-3 block text-sm font-semibold text-primary">Ver artículos →</span>
            </a>
          ))
        )
      }
    </div>
  </section>
</Layout>
