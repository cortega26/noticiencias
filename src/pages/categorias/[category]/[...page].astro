---
import { getStaticPathsBlogCategory } from '~/utils/blog';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionFront from '~/components/common/SectionFront.astro';
import Pagination from '~/components/common/Pagination.astro';
import { configuredCategorySections } from '~/utils/categorySections';
import { getTopicFrequency } from '~/utils/hub';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

export const getStaticPaths = getStaticPathsBlogCategory satisfies GetStaticPaths;

const { page, category } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const configuredCategory = configuredCategorySections.find((item) => item.slug === category?.slug);
const topics = getTopicFrequency(page.data, 8);

const metadata = {
  title: `Categoría: ${category?.title || ''}`,
  description:
    configuredCategory?.description ||
    `Últimas historias de ${category?.title || 'esta categoría'} en Noticiencias.`,
  robots: {
    index: true,
    follow: true,
  },
};
---

<BaseLayout metadata={metadata}>
  <SectionFront
    title={category?.title || 'Categoría'}
    description={configuredCategory?.description}
    posts={page.data}
    topics={topics}
    taxonomy={category}
  />
  <div class="mx-auto max-w-6xl px-4 pb-12 sm:px-6">
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </div>
</BaseLayout>
