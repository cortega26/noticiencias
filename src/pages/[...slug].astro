---
import { getPermalink } from '~/utils/permalinks';
import { fetchPosts, getRelatedPosts } from '~/utils/blog';
import PostLayout from '~/layouts/PostLayout.astro';
import type { Post } from '~/types';

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map((post) => ({
    params: { slug: post.permalink?.replace(/^\/|\/$/g, '') },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const url = post.permalink || getPermalink(post.slug, 'post');
const relatedPosts = await getRelatedPosts(post, 4);
---

<PostLayout post={post} url={url} relatedPosts={relatedPosts}>
  {post.Content ? <post.Content /> : <Fragment set:html={post.content} />}
</PostLayout>
