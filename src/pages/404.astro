---
import Layout from '~/layouts/BaseLayout.astro';
import Button from '~/components/ds/atoms/Button.astro';
import { getHomePermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Error 404 - Página no encontrada',
  description:
    'Lo sentimos, la página que buscas no existe o ha sido movida. Explora nuestra portada científica para encontrar los últimos artículos de Noticiencias.',
};
---

<Layout metadata={metadata}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h1 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h1>
        <p class="text-3xl font-semibold md:text-3xl">Página no encontrada</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          Lo sentimos, no pudimos encontrar la página que buscas.
        </p>
        <Button href={getHomePermalink()} variant="secondary" rel="noopener noreferrer"
          >Volver al inicio</Button
        >
      </div>
    </div>
  </section>
</Layout>
