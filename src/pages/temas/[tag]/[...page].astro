---
import { fetchPosts, getStaticPathsBlogTag } from '~/utils/blog';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArticleCard from '~/components/ds/organisms/ArticleCard.astro';
import Pagination from '~/components/common/Pagination.astro';
import TopicHubHeader from '~/components/common/TopicHubHeader.astro';
import { getRelatedTopics } from '~/utils/hub';

export const getStaticPaths = getStaticPathsBlogTag;

const { page, tag } = Astro.props;
const allPosts = await fetchPosts();
const relatedTopics = getRelatedTopics(allPosts, tag?.slug || '', 8);

const metadata = {
  title: `Etiqueta: ${tag?.title || ''}`,
  description: `Artículos, contexto y temas relacionados sobre ${tag?.title || 'este tema'} en Noticiencias.`,
  robots: {
    index: false, // As per config.yaml
    follow: true,
  },
};
---

<BaseLayout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <TopicHubHeader title={tag?.title || 'Tema'} total={page.total} relatedTopics={relatedTopics} />

    <div class="grid gap-6">
      {page.data.map((post) => <ArticleCard post={post} variant="row" />)}
    </div>

    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</BaseLayout>
