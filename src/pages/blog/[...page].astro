---
import { fetchPosts } from '~/utils/blog';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArticleCard from '~/components/ds/organisms/ArticleCard.astro';
import Pagination from '~/components/common/Pagination.astro';
import TopicStrip from '~/components/common/TopicStrip.astro';
import { getTopicFrequency } from '~/utils/hub';

import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await fetchPosts();
  // Sort by date not needed as fetchPosts does it?
  // fetchPosts line 114 sorts. So we can remove sort here.

  return paginate(allPosts, {
    pageSize: 10,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const topics = getTopicFrequency(page.data, 10);
const metadata = {
  title: `Blog`,
  description:
    'Archivo cronológico de artículos de ciencia y tecnología publicados por Noticiencias.',
  robots: {
    index: true,
    follow: true,
  },
};
---

<BaseLayout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mb-8 border-b border-border-subtle pb-5">
      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-5xl">
        Archivo
      </h1>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-text-muted">
        Todas las historias publicadas por Noticiencias, ordenadas de la más reciente a la más
        antigua.
      </p>
    </header>

    <TopicStrip
      topics={topics}
      title="En seguimiento"
      description="Temas frecuentes en el archivo. Filtra por área."
      class="mb-8"
    />

    <div class="grid gap-6">
      {page.data.map((post) => <ArticleCard post={post} variant="row" />)}
    </div>

    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</BaseLayout>
