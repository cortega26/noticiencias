---
import BaseLayout from '~/layouts/BaseLayout.astro';
import DailyDesk from '~/components/common/DailyDesk.astro';
import { fetchPosts } from '~/utils/blog';
import {
  buildCategoryRails,
  getTopicFrequency,
  selectContextPosts,
  selectFeaturedPosts,
} from '~/utils/hub';
import { configuredCategorySections } from '~/utils/categorySections';

const allPosts = await fetchPosts();
const leadPosts = selectFeaturedPosts(allPosts, 3);
const leadPostIds = new Set(leadPosts.map((post) => post.id));
const latestPosts = allPosts.filter((post) => !leadPostIds.has(post.id)).slice(0, 6);
const contextPosts = selectContextPosts(allPosts, 3);
const topicRadar = getTopicFrequency(allPosts.slice(0, 18), 12);
const categoryRails = buildCategoryRails(
  allPosts,
  configuredCategorySections.map(({ slug, title }) => ({ slug, title })),
  3
);

const metadata = {
  title: 'Noticiencias - Portada científica en español.',
  description:
    'La edición diaria de ciencia y tecnología para seguir hallazgos, evidencia y temas abiertos en español.',
  ignoreTitleTemplate: true,
};
---

<BaseLayout metadata={metadata}>
  <DailyDesk
    leadPosts={leadPosts}
    latestPosts={latestPosts}
    contextPosts={contextPosts}
    categoryRails={categoryRails}
    topicRadar={topicRadar}
  />
</BaseLayout>
