---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ReportForm from '~/components/template/widgets/ReportForm.astro';

const metadata = {
  title: 'Reportar un problema',
  description:
    'Canal para reportar errores factuales, fuentes incorrectas o problemas técnicos en Noticiencias.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<BaseLayout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mb-8 border-b border-border-subtle pb-5">
      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-5xl">
        Reportar un problema
      </h1>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-text-muted">
        Canal para correcciones factuales, fuentes mal citadas y problemas técnicos que afecten la
        lectura.
      </p>
    </header>

    <div class="mb-10 grid grid-cols-1 gap-8 md:grid-cols-2">
      <section class="border-t border-border-subtle pt-5">
        <h2 class="mb-4 font-heading text-xl font-bold text-text-body">
          Qué consideramos un problema
        </h2>
        <ul class="space-y-2 text-sm leading-relaxed text-text-muted">
          <li>Errores factuales verificables</li>
          <li>Fuentes incorrectas o mal citadas</li>
          <li>Datos, gráficos o cifras mal interpretadas</li>
          <li>Errores de traducción sustanciales</li>
          <li>Enlaces rotos a fuentes primarias</li>
          <li>Fallas técnicas o visuales de lectura</li>
        </ul>
      </section>

      <section class="border-t border-border-subtle pt-5">
        <h2 class="mb-4 font-heading text-xl font-bold text-text-body">
          Qué no corresponde a este canal
        </h2>
        <ul class="space-y-2 text-sm leading-relaxed text-text-muted">
          <li>Desacuerdos ideológicos o políticos</li>
          <li>Opiniones personales sobre el tema</li>
          <li>Demandas de equilibrar opiniones sin evidencia</li>
          <li>Quejas subjetivas o feedback general</li>
        </ul>
      </section>
    </div>

    <div class="max-w-3xl mx-auto">
      <ReportForm />
    </div>
  </section>
</BaseLayout>
