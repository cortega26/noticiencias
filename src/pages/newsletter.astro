---
import Layout from '~/layouts/BaseLayout.astro';
import NewsletterCapture from '~/components/common/NewsletterCapture.astro';

const metadata = {
  title: 'Newsletter | Noticiencias',
  description: 'Suscríbete al resumen semanal de ciencia y tecnología de Noticiencias.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mb-8 border-b border-border-subtle pb-5">
      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-5xl">
        Newsletter
      </h1>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-text-muted">
        Un resumen semanal para seguir ciencia y tecnología con calma: qué pasó, por qué importa y
        qué evidencia lo sostiene.
      </p>
    </header>

    <NewsletterCapture class="px-0" />

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      <section class="border-t border-border-subtle pt-4">
        <h2 class="font-heading text-xl font-bold text-text-body">Claridad</h2>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Menos jerga y más contexto para entender la noticia sin simplificarla de más.
        </p>
      </section>
      <section class="border-t border-border-subtle pt-4">
        <h2 class="font-heading text-xl font-bold text-text-body">Fuentes</h2>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Cada edición prioriza trazabilidad: papers, instituciones, laboratorios y enlaces
          originales.
        </p>
      </section>
      <section class="border-t border-border-subtle pt-4">
        <h2 class="font-heading text-xl font-bold text-text-body">Ritmo</h2>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Una lectura semanal, no una avalancha de alertas.
        </p>
      </section>
    </div>
  </section>
</Layout>
