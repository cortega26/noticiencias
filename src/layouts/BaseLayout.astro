---
import Layout from '~/layouts/template/Layout.astro';
import Header from '~/components/template/widgets/Header.astro';
import Footer from '~/components/ds/organisms/Footer.astro';

import { headerData, footerData } from '~/navigation';
import type { MetaData } from '~/types';

interface Props {
  metadata?: MetaData;
  frontmatter?: {
    title?: string;
    description?: string;
    excerpt?: string;
  };
}

const { metadata = {}, frontmatter } = Astro.props as Props;

const resolvedMetadata: MetaData = {
  title: frontmatter?.title,
  description: frontmatter?.description ?? frontmatter?.excerpt,
  ...metadata,
};
---

<Layout metadata={resolvedMetadata}>
  <slot name="announcement" />
  <slot name="header">
    <Header {...headerData} isSticky showRssFeed showToggleTheme />
  </slot>
  <main id="main-content">
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
