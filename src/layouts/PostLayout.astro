---
import Image from '~/components/common/Image.astro';
import RelatedReading from '~/components/common/RelatedReading.astro';
import TopicStrip from '~/components/common/TopicStrip.astro';
import TrustPanel from '~/components/common/TrustPanel.astro';
import TopicBadge from '~/components/ds/atoms/TopicBadge.astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { findImage } from '~/utils/images';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import type { MetaData, Post } from '~/types';

interface Props {
  post: Post;
  relatedPosts?: Post[];
  url: string | URL;
}

const { post, relatedPosts = [], url } = Astro.props;
const image = (await findImage(post.image)) ?? post.image;
const imageSrc = typeof post.image === 'string' ? post.image : post.image?.src;
const imageAlt = post.image_alt || post.title;
const displayAuthor = /noticiencias\s+ai/i.test(post.author ?? '')
  ? 'Equipo Noticiencias'
  : post.author || 'Noticiencias';
const summaryPoints = post.summary_points?.length
  ? post.summary_points
  : post.excerpt
    ? [post.excerpt]
    : [];
const articleTopics = (post.tags ?? []).map((tag) => ({
  slug: tag.slug,
  title: tag.title,
  count: 1,
}));
const sourceFallback =
  post.sources?.length || !post.source_url
    ? post.sources
    : [
        {
          title: post.refinery_id || 'Fuente original',
          url: post.source_url,
        },
      ];

const metadata: MetaData = {
  title: post.title,
  description: post.excerpt,
  canonical: String(getCanonical(typeof url === 'string' ? url : url.pathname)),
  openGraph: {
    type: 'article',
    images: imageSrc ? [{ url: imageSrc }] : [],
  },
};

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.title.substring(0, 110),
  image: imageSrc ? [imageSrc] : [],
  datePublished: post.publishDate.toISOString(),
  dateModified: (post.updateDate ?? post.publishDate).toISOString(),
  author: [
    {
      '@type': 'Organization',
      name: displayAuthor,
      url: 'https://noticiencias.com/nosotros/',
    },
  ],
});
---

<BaseLayout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={schema} />

  <article class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mx-auto max-w-5xl border-b border-border-subtle pb-8">
      <div class="mb-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-text-muted">
        {
          post.category && (
            <TopicBadge
              topic={post.category.title}
              href={getPermalink(post.category.slug, 'category')}
            />
          )
        }
        <time datetime={post.publishDate.toISOString()}>{getFormattedDate(post.publishDate)}</time>
        {post.readingTime && <span>{post.readingTime} min lectura</span>}
      </div>

      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-6xl">
        {post.title}
      </h1>

      {post.excerpt && <p class="mt-5 text-xl leading-relaxed text-text-muted">{post.excerpt}</p>}

      <p class="mt-6 text-sm font-medium text-text-muted">
        Por <a href="/nosotros/" class="text-text-body underline-offset-4 hover:underline"
          >{displayAuthor}</a
        >
      </p>

      {
        image && (
          <figure class="mt-8">
            <div class="overflow-hidden rounded-md bg-surface-highlight">
              <Image
                src={image}
                alt={imageAlt}
                width={1280}
                height={720}
                widths={[480, 900, 1280, 1600]}
                sizes="(max-width: 1024px) 100vw, 1100px"
                class="aspect-[16/9] w-full object-cover"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <figcaption class="mt-2 text-sm text-text-muted">{imageAlt}</figcaption>
          </figure>
        )
      }
    </header>

    <div class="mx-auto mt-10 grid max-w-5xl gap-10 lg:grid-cols-[220px_1fr]">
      <aside class="hidden lg:block">
        <div class="sticky top-24 border-t border-border-subtle pt-4 text-sm text-text-muted">
          <p class="font-semibold text-text-body">Edición</p>
          <p class="mt-2">Resumen, alcance, fuentes y lecturas relacionadas.</p>
        </div>
      </aside>

      <div>
        {
          summaryPoints.length > 0 && (
            <section class="not-prose mb-8 rounded-md border border-border-subtle bg-surface-paper p-5">
              <h2 class="font-heading text-xl font-bold text-text-body">En breve</h2>
              <ul class="mt-3 grid gap-2 text-text-muted">
                {summaryPoints.map((point) => (
                  <li class="pl-4 [text-indent:-1rem]">
                    <span class="font-bold text-primary">•</span> {point}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          post.why_it_matters && post.why_it_matters.length > 0 && (
            <section class="not-prose mb-8 border-l-4 border-primary bg-surface-paper p-5">
              <h2 class="font-heading text-xl font-bold text-text-body">Qué cambia</h2>
              <ul class="mt-3 grid gap-2 text-text-muted">
                {post.why_it_matters.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          )
        }

        <div
          class="prose prose-lg max-w-none dark:prose-invert prose-headings:font-heading prose-headings:font-bold prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-md prose-li:my-0"
        >
          <slot />
        </div>

        {
          post.glossary && post.glossary.length > 0 && (
            <section class="not-prose mt-10 rounded-md border border-border-subtle p-5">
              <h2 class="font-heading text-xl font-bold text-text-body">Glosario breve</h2>
              <dl class="mt-4 grid gap-4">
                {post.glossary.map((entry) => (
                  <div>
                    <dt class="font-semibold text-text-body">{entry.term}</dt>
                    <dd class="mt-1 text-sm leading-relaxed text-text-muted">{entry.definition}</dd>
                  </div>
                ))}
              </dl>
            </section>
          )
        }

        <TrustPanel
          confidence={post.confidence}
          factCheck={post.fact_check}
          sources={sourceFallback}
          uncertaintyNote={post.uncertainty_note}
          translationMethod={post.translation_method}
          reviewStatus={post.review_status}
        />

        <TopicStrip
          topics={articleTopics}
          title="Seguir temas"
          description="Más historias conectadas con esta lectura."
          class="not-prose mt-8"
        />

        <RelatedReading posts={relatedPosts} />
      </div>
    </div>
  </article>
</BaseLayout>
