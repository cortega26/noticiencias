---
import Layout from '~/layouts/BaseLayout.astro';

import type { MetaData } from '~/types';

export interface Props {
  frontmatter: {
    title?: string;
    description?: string;
    excerpt?: string;
  };
}

const { frontmatter } = Astro.props;

const metadata: MetaData = {
  title: frontmatter?.title,
  description: frontmatter?.description ?? frontmatter?.excerpt,
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="border-b border-border-subtle pb-5">
      <h1 class="font-heading text-4xl font-black leading-tight text-text-body md:text-5xl">
        {frontmatter.title}
      </h1>
      {
        (frontmatter.description || frontmatter.excerpt) && (
          <p class="mt-3 text-lg leading-relaxed text-text-muted">
            {frontmatter.description ?? frontmatter.excerpt}
          </p>
        )
      }
    </header>
    <div
      class="prose prose-lg mt-8 max-w-none dark:prose-invert prose-headings:font-heading prose-headings:font-bold prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-md"
    >
      <slot />
    </div>
  </section>
</Layout>
