---
import { APP_CONFIG } from 'astrowind:config';

interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = 'Recibe el resumen semanal de Noticiencias',
  description = 'Una selección breve de ciencia y tecnología, con contexto y fuentes, pensada para leerse sin ruido.',
  class: className = '',
} = Astro.props;

const endpoint = APP_CONFIG?.form?.endpoint || '';
const isEnabled = endpoint.length > 0;
---

<section class={`border-y border-border-subtle bg-surface-paper px-4 py-10 sm:px-6 ${className}`}>
  <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-[1fr_420px] md:items-center">
    <div>
      <h2 class="font-heading text-3xl font-bold leading-tight text-text-body">{title}</h2>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-text-muted">{description}</p>
    </div>

    <form
      action={isEnabled ? endpoint : undefined}
      method="post"
      class="grid gap-3 sm:grid-cols-[1fr_auto]"
      aria-label="Suscripción al boletín"
    >
      <label class="sr-only" for="newsletter-email">Correo electrónico</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="tu@email.com"
        required
        disabled={!isEnabled}
        class="min-h-11 rounded-md border border-border-subtle bg-white px-4 text-base text-text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary disabled:cursor-not-allowed disabled:bg-surface-highlight dark:bg-slate-950"
      />
      <button
        type="submit"
        disabled={!isEnabled}
        class="min-h-11 rounded-md bg-primary px-5 text-sm font-semibold text-white hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-primary disabled:cursor-not-allowed disabled:bg-slate-400"
      >
        Suscribirme
      </button>
      <p class="text-xs text-text-muted sm:col-span-2" role="status">
        {
          isEnabled
            ? 'Sin spam. Solo contexto útil.'
            : 'La captura de correos se activará al configurar el endpoint del formulario.'
        }
      </p>
    </form>
  </div>
</section>
