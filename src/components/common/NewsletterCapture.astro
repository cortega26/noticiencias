---
import { APP_CONFIG } from 'astrowind:config';
import { getAsset } from '~/utils/permalinks';

interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = 'Boletín Noticiencias',
  description = 'Una edición semanal con hallazgos, fuentes y temas para guardar.',
  class: className = '',
} = Astro.props;

const endpoint = APP_CONFIG?.form?.endpoint || '';
const isEnabled = endpoint.length > 0;
---

<section
  class={`rounded-xl border border-border-subtle bg-surface-paper px-6 py-10 sm:px-8 shadow-sm hover:shadow-md transition-all duration-300 ${className}`}
>
  <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-[1fr_420px] md:items-center">
    <div>
      <h2 class="font-heading text-3xl font-bold leading-tight text-text-body">{title}</h2>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-text-muted">{description}</p>
    </div>

    {
      isEnabled ? (
        <form
          action={endpoint}
          method="post"
          class="grid gap-3 sm:grid-cols-[1fr_auto]"
          aria-label="Suscripción al boletín"
        >
          <label class="sr-only" for="newsletter-email">
            Correo electrónico
          </label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            placeholder="tu@email.com"
            required
            class="min-h-11 rounded-md border border-border-subtle bg-white px-4 text-base text-text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 dark:bg-slate-950"
          />
          <button
            type="submit"
            class="min-h-11 rounded-md bg-primary px-5 text-sm font-semibold text-white hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-primary/20 active:scale-[0.98] transition-all duration-200"
          >
            Suscribirme
          </button>
          <p class="text-xs text-text-muted sm:col-span-2">
            Una entrega semanal. Baja inmediata desde cada correo.
          </p>
        </form>
      ) : (
        <div class="flex flex-wrap gap-3">
          <a
            href={getAsset('/rss.xml')}
            class="rounded-md border border-border-subtle px-4 py-2.5 text-sm font-semibold text-text-body hover:border-primary hover:text-primary transition-colors duration-200"
          >
            RSS
          </a>
          <a
            href="/blog/"
            class="rounded-md border border-border-subtle px-4 py-2.5 text-sm font-semibold text-text-body hover:border-primary hover:text-primary transition-colors duration-200"
          >
            Ver archivo
          </a>
        </div>
      )
    }
  </div>
</section>
