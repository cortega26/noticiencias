---
import ArticleCard from '~/components/ds/organisms/ArticleCard.astro';
import SectionHeading from '~/components/ds/molecules/SectionHeading.astro';
import NewsletterCapture from '~/components/common/NewsletterCapture.astro';
import TopicStrip from '~/components/common/TopicStrip.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import type { CategoryRail, TopicFrequency } from '~/utils/hub';
import type { Post } from '~/types';

interface Props {
  leadPosts: Post[];
  latestPosts: Post[];
  contextPosts: Post[];
  categoryRails: CategoryRail[];
  topicRadar: TopicFrequency[];
}

const { leadPosts, latestPosts, contextPosts, categoryRails, topicRadar } = Astro.props;
const [leadPost, ...secondaryLeadPosts] = leadPosts;
---

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:py-12">
  <header class="mb-8 pb-6 border-b border-border-subtle/50 relative">
    <p class="mb-2 text-xs font-bold text-primary uppercase tracking-wider">Portada</p>
    <h1 class="max-w-5xl font-heading text-4xl font-black leading-none text-text-body md:text-6xl">
      La ciencia que conviene seguir hoy.
    </h1>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-text-muted">
      Una edición en español para entrar rápido en los hallazgos, las dudas y las consecuencias de
      cada historia.
    </p>
    <div
      class="absolute bottom-0 left-0 w-32 h-[3px] bg-gradient-to-r from-primary to-accent rounded-full"
    >
    </div>
  </header>

  <TopicStrip
    topics={topicRadar}
    showCounts
    class="mb-8"
    description="Los temas que más se repiten en la edición reciente."
  />

  {
    leadPost && (
      <section aria-label="Historia principal">
        <ArticleCard post={leadPost} variant="lead" />
        {secondaryLeadPosts.length > 0 && (
          <div class="mt-6 grid gap-6 md:grid-cols-2">
            {secondaryLeadPosts.map((post) => (
              <ArticleCard post={post} variant="compact" />
            ))}
          </div>
        )}
      </section>
    )
  }

  <section class="mt-12 grid gap-10 lg:grid-cols-[1fr_320px]">
    <div>
      <SectionHeading title="Última edición" href="/blog/" linkText="Archivo completo" />
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        {latestPosts.map((post) => <ArticleCard post={post} variant="standard" />)}
      </div>
    </div>

    <aside class="lg:border-l lg:border-border-subtle lg:pl-8">
      <SectionHeading title="Una vez por semana, solo lo que vale guardar" level={2} />
      <div class="mt-5 grid gap-4 text-sm leading-relaxed text-text-muted">
        <p>
          El boletín reúne las piezas que valió la pena leer dos veces del archivo reciente. RSS
          también disponible para quien prefiere su propio lector.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/newsletter/"
            class="rounded-md border border-border-subtle px-3 py-2 font-semibold text-text-body hover:border-primary hover:text-primary"
          >
            Boletín
          </a>
          <a
            href={getAsset('/rss.xml')}
            class="rounded-md border border-border-subtle px-3 py-2 font-semibold text-text-body hover:border-primary hover:text-primary"
          >
            RSS
          </a>
        </div>
      </div>
    </aside>
  </section>

  {
    contextPosts.length > 0 && (
      <section class="mt-12">
        <SectionHeading
          title="Qué cambia"
          description="Historias recientes que dejan una consecuencia clara sobre la mesa."
        />
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {contextPosts.map((post) => (
            <ArticleCard post={post} variant="consequence" />
          ))}
        </div>
      </section>
    )
  }

  <section class="mt-12">
    <SectionHeading
      title="Secciones"
      description="La portada también se puede leer por área, de la actualidad al archivo."
    />
    <div class="mt-6 grid gap-8 lg:grid-cols-2">
      {
        categoryRails.map((rail) => (
          <section class="border-t border-border-subtle pt-5">
            <div class="mb-4 flex items-baseline justify-between gap-4">
              <h2 class="font-heading text-2xl font-bold text-text-body">{rail.category.title}</h2>
              <a
                href={getPermalink(rail.category.slug, 'category')}
                class="text-sm font-semibold text-primary underline-offset-4 hover:underline"
              >
                Ver sección
              </a>
            </div>
            <div class="grid gap-5">
              {rail.posts.map((post) => (
                <ArticleCard post={post} variant="row" showExcerpt={false} />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <section class="mt-12 border-t border-border-subtle pt-5">
    <SectionHeading
      title="Para leer con criterio"
      description="Piezas para volver cuando una noticia científica llega demasiado vestida de promesa."
    />
    <div class="mt-6 grid gap-5 md:grid-cols-3">
      <a
        href="/recursos/detector-de-hype/"
        class="border-t border-border-subtle pt-4 text-text-body hover:text-primary"
      >
        <h3 class="font-heading text-xl font-bold">Detector de hype</h3>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Una guía breve para leer promesas científicas con mejores preguntas.
        </p>
      </a>
      <a
        href="/metodologia/"
        class="border-t border-border-subtle pt-4 text-text-body hover:text-primary"
      >
        <h3 class="font-heading text-xl font-bold">Cómo trabajamos</h3>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          El recorrido editorial desde la fuente original hasta la publicación.
        </p>
      </a>
      <a
        href="/buscar/"
        class="border-t border-border-subtle pt-4 text-text-body hover:text-primary"
      >
        <h3 class="font-heading text-xl font-bold">Buscar en el archivo</h3>
        <p class="mt-2 text-sm leading-relaxed text-text-muted">
          Encuentra temas, categorías y fuentes ya publicadas por Noticiencias.
        </p>
      </a>
    </div>
  </section>
</div>

<NewsletterCapture
  title="Boletín Noticiencias"
  description="Una edición semanal con hallazgos, fuentes y temas para guardar."
  class="mt-4"
/>
