---
interface Props {
  title: string;
  description?: string;
  href?: string;
  linkText?: string;
  level?: 1 | 2 | 3;
  class?: string;
}

const {
  title,
  description,
  href,
  linkText = 'Ver más',
  level = 2,
  class: className = '',
} = Astro.props;

const headingClass = 'font-heading text-2xl md:text-3xl font-bold leading-tight text-text-body';
---

<header class={`border-b border-border-subtle pb-3 ${className}`}>
  <div class="flex items-end justify-between gap-4">
    <div>
      {level === 1 && <h1 class={headingClass}>{title}</h1>}
      {level === 2 && <h2 class={headingClass}>{title}</h2>}
      {level === 3 && <h3 class={headingClass}>{title}</h3>}
      {
        description && (
          <p class="mt-2 max-w-3xl text-sm md:text-base text-text-muted">{description}</p>
        )
      }
    </div>
    {
      href && (
        <a
          href={href}
          class="shrink-0 text-sm font-semibold text-primary underline-offset-4 hover:underline"
        >
          {linkText}
        </a>
      )
    }
  </div>
</header>
