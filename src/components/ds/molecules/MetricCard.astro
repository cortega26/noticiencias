---
interface Props {
  title: string;
  value: string | number;
  subtitle?: string;
  trend?: 'up' | 'down' | 'neutral';
  class?: string;
}

const { title, value, subtitle, trend = 'neutral', class: className = '' } = Astro.props;

const trendColors = {
  up: 'text-green-600 dark:text-green-400',
  down: 'text-red-600 dark:text-red-400',
  neutral: 'text-text-muted',
};

const trendIcons = {
  up: '↑',
  down: '↓',
  neutral: '→',
};
---

<div class={`bg-surface-paper rounded-lg shadow-sm border border-border-subtle p-5 ${className}`}>
  <dt class="text-sm font-medium text-text-muted truncate">{title}</dt>
  <dd class="mt-2 flex items-baseline gap-2">
    <span class="text-3xl font-bold text-text-body">{value}</span>
    {
      subtitle && (
        <span class={`text-sm ${trendColors[trend]}`}>
          {trendIcons[trend]} {subtitle}
        </span>
      )
    }
  </dd>
</div>
