---
interface HealthCheck {
  name: string;
  description: string;
  status: 'pass' | 'fail' | 'warning' | 'unknown';
  detail?: string;
}

interface Props {
  checks: HealthCheck[];
  class?: string;
}

const { checks, class: className = '' } = Astro.props;

const statusStyles = {
  pass: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  fail: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
  warning: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
  unknown: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400',
};

const statusIcons = {
  pass: '✅',
  fail: '❌',
  warning: '⚠️',
  unknown: '❓',
};
---

<div class={`bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-border-subtle ${className}`}>
  <div class="px-5 py-4 border-b border-border-subtle">
    <h3 class="text-lg font-heading font-bold text-text-body">Salud del Pipeline</h3>
  </div>
  <ul class="divide-y divide-border-subtle">
    {checks.map((check) => (
      <li class="px-5 py-3 flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-sm font-medium text-text-body">{check.name}</p>
          <p class="text-xs text-text-muted mt-0.5">{check.description}</p>
          {check.detail && <p class="text-xs text-text-muted mt-0.5">{check.detail}</p>}
        </div>
        <span class={`shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusStyles[check.status]}`}>
          {statusIcons[check.status]} {check.status === 'pass' ? 'OK' : check.status === 'fail' ? 'ERROR' : check.status === 'warning' ? 'WARN' : 'N/A'}
        </span>
      </li>
    ))}
  </ul>
</div>
