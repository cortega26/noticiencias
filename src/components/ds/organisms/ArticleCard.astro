---
import Image from '~/components/common/Image.astro';
import TagPill from '~/components/ds/atoms/TagPill.astro';
import TopicBadge from '~/components/ds/atoms/TopicBadge.astro';
import InvestigationBadge from '~/components/ds/atoms/InvestigationBadge.astro';
import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/date';
import type { Post } from '~/types';

interface Props {
  post: Post;
  variant?: 'lead' | 'standard' | 'compact' | 'row' | 'consequence';
  showExcerpt?: boolean;
  showImage?: boolean;
  showTags?: boolean;
  class?: string;
}

const {
  post,
  variant = 'standard',
  showExcerpt = variant !== 'compact' && variant !== 'consequence',
  showImage = variant !== 'consequence',
  showTags = variant !== 'lead' && variant !== 'consequence',
  class: className = '',
} = Astro.props;

const image = showImage ? await findImage(post.image) : undefined;
const href = getPermalink(post.permalink, 'post');
const imageAlt = post.image_alt ?? '';

const styles = {
  lead: {
    article: 'grid gap-5 lg:grid-cols-[1.25fr_0.75fr] border-b border-border-subtle pb-6',
    image: 'aspect-[16/10] lg:aspect-[4/3]',
    title: 'text-3xl md:text-5xl',
    excerpt: 'text-base md:text-lg',
  },
  standard: {
    article: 'border-b border-border-subtle pb-5',
    image: 'aspect-[16/10]',
    title: 'text-xl md:text-2xl',
    excerpt: 'text-sm md:text-base',
  },
  compact: {
    article: 'border-b border-border-subtle pb-4',
    image: 'aspect-[16/10]',
    title: 'text-lg',
    excerpt: 'text-sm',
  },
  row: {
    article:
      'grid grid-cols-[96px_1fr] gap-4 border-b border-border-subtle pb-4 sm:grid-cols-[160px_1fr]',
    image: 'aspect-square sm:aspect-[4/3]',
    title: 'text-lg md:text-xl',
    excerpt: 'text-sm',
  },
  consequence: {
    article: 'border border-primary/10 bg-surface-paper rounded-md p-4 shadow-sm flex flex-col',
    image: '',
    title: 'text-sm font-medium text-text-muted mt-2',
    excerpt: '',
  },
}[variant];

const kicker = post.category?.title || 'ÁMBITO';
const consequenceHeadline = post.why_it_matters?.[0] || post.title;
---

{
  variant === 'consequence' ? (
    <article class={`group ${styles.article} ${className}`}>
      <span class="text-xs font-bold uppercase tracking-wider text-primary mb-1">{kicker}</span>
      <h3 class="text-lg font-bold text-text-body leading-tight">
        <a
          href={href}
          class="transition-colors duration-200 hover:text-primary hover:underline underline-offset-4"
        >
          {consequenceHeadline}
        </a>
      </h3>
      <a
        href={href}
        class="text-sm font-medium text-text-muted mt-2 block hover:text-primary hover:underline underline-offset-4"
      >
        Artículo: {post.title}
      </a>
    </article>
  ) : (
    <article class={`group ${styles.article} ${className}`}>
      {image && (
        <a
          href={href}
          class={`block overflow-hidden rounded-md bg-surface-highlight ${styles.image}`}
        >
          <Image
            src={image}
            alt={imageAlt}
            width={variant === 'lead' ? 1200 : 640}
            height={variant === 'lead' ? 800 : 420}
            widths={[320, 640, 900, 1200]}
            sizes={
              variant === 'lead'
                ? '(max-width: 1024px) 100vw, 760px'
                : '(max-width: 768px) 100vw, 420px'
            }
            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105 motion-reduce:transition-none motion-reduce:transform-none"
            loading={variant === 'lead' ? 'eager' : 'lazy'}
            fetchpriority={variant === 'lead' ? 'high' : 'auto'}
          />
        </a>
      )}

      <div
        class:list={[
          'flex min-w-0 flex-col',
          { 'mt-4': image && (variant === 'standard' || variant === 'compact') },
        ]}
      >
        <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-text-muted">
          {post.investigation && <InvestigationBadge size="sm" />}
          {post.category && (
            <TopicBadge
              topic={post.category.title}
              href={getPermalink(post.category.slug, 'category')}
              size="sm"
            />
          )}
          <time datetime={post.publishDate.toISOString()}>
            {getFormattedDate(post.publishDate, 'relative')}
          </time>
          {post.readingTime && <span>{post.readingTime} min lectura</span>}
        </div>

        <h2
          class={`${post.investigation && variant === 'lead' ? 'font-serif' : 'font-heading'} font-bold leading-tight text-text-body ${styles.title}`}
        >
          <a
            href={href}
            class="transition-colors duration-200 hover:text-primary hover:underline underline-offset-4"
          >
            {post.title}
          </a>
        </h2>

        {showExcerpt && post.excerpt && (
          <p class={`mt-3 line-clamp-3 leading-relaxed text-text-muted ${styles.excerpt}`}>
            {post.excerpt}
          </p>
        )}

        {showTags && post.tags && post.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.tags.slice(0, 3).map((tag) => (
              <TagPill title={tag.title} href={getPermalink(tag.slug, 'tag')} size="sm" />
            ))}
          </div>
        )}
      </div>
    </article>
  )
}
