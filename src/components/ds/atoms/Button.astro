---
import { Icon } from 'astro-icon/components';

interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'link' | 'tertiary' | null;
  size?: 'sm' | 'md' | 'lg' | null;
  icon?: string | null;
  iconPosition?: 'left' | 'right' | null;
  href?: string | URL | null;
  text?: string | null;
  class?: string | null;
  type?: 'button' | 'submit' | 'reset' | null;
  [key: string]: any;
}

const {
  variant: rawVariant,
  size: rawSize,
  icon,
  iconPosition: rawIconPosition,
  href,
  text,
  class: rawClassName,
  type: rawType,
  ...rest
} = Astro.props;

const variant = rawVariant ?? 'primary';
const size = rawSize ?? 'md';
const iconPosition = rawIconPosition ?? 'left';
const type = rawType ?? 'button';
const className = rawClassName ?? '';

// Map legacy tertiary to outline
const effectiveVariant = variant === 'tertiary' ? 'outline' : variant;

// Editorial buttons use rounded-md (not rounded-full pills, which read as
// social-media) per docs/EDITORIAL_VOICE.md decision D8.
const baseStyles =
  'inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary/40 focus:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none';

const variants = {
  primary: 'bg-primary text-text-inverse hover:bg-secondary',
  secondary:
    'border border-border-subtle bg-surface-paper text-text-body hover:border-primary hover:text-primary',
  outline:
    'border border-border-subtle bg-transparent text-text-body hover:bg-surface-paper hover:text-primary',
  ghost: 'bg-transparent text-text-body hover:bg-surface-highlight',
  link: 'text-primary underline-offset-4 hover:underline p-0 h-auto',
};

const sizes = {
  sm: 'text-xs px-3 py-1.5',
  md: 'text-sm px-4 py-2',
  lg: 'text-base px-6 py-3',
};

const hasHref = href !== undefined && href !== null && href !== '';
const Tag = hasHref ? 'a' : 'button';
const resolvedHref = hasHref ? String(href) : undefined;
---

<Tag
  type={hasHref ? undefined : type}
  href={resolvedHref}
  class:list={[
    baseStyles,
    variants[effectiveVariant],
    effectiveVariant !== 'link' && sizes[size],
    className,
  ]}
  {...rest}
>
  {icon && iconPosition === 'left' && <Icon name={icon} class="w-4 h-4 mr-2" />}
  {text ? <Fragment set:html={text} /> : <slot />}
  {icon && iconPosition === 'right' && <Icon name={icon} class="w-4 h-4 ml-2" />}
</Tag>
